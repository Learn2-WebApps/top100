# =============================================================
# Firebase 클라이언트 SDK (브라우저 공개 가능 — NEXT_PUBLIC_ 접두어 필수)
# Firebase 콘솔 > 프로젝트 설정 > 앱 > 웹 앱 > 구성(Config)에서 확인
# =============================================================
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSy...
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxxxxxx

# =============================================================
# Firebase Admin SDK (서버 전용 — 절대 클라이언트에 노출하지 마세요)
# Firebase 콘솔 > 프로젝트 설정 > 서비스 계정 > 새 비공개 키 생성에서 확인
# =============================================================
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com

# Private key: JSON 파일에서 "private_key" 값 그대로 붙여넣기 (큰따옴표 포함)
# Vercel 등록 시: -----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEv...\n-----END PRIVATE KEY-----\n"
